# Copy to .env and fill in values. Never commit .env to version control.
# Used by db.py and tabs/email_notifications.py (when python-dotenv is installed).

# --- MySQL (required in production) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=contract_app
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=contract_db

# Optional: managed MySQL SSL (RDS, Azure Database for MySQL, etc.)
# MYSQL_SSL_CA=/path/to/ca.pem
# Or disable SSL only for local/dev if your driver requires it:
# MYSQL_SSL_DISABLED=true

# --- Browser session cookie (login persistence across page reload; 8h token) ---
# Use a long random string in production. If unset, a dev default is used (not safe for production).
# SESSION_SECRET=

# --- Email (optional; weekly / reminder notifications) ---
# EMAIL_SMTP_SERVER=smtp.office365.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# EMAIL_FROM_NAME=Contract Management System
